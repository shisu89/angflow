{
  "name": "@angflow/angular",
  "version": "0.3.4",
  "type": "module",
  "description": "Angular Flow - A highly customizable Angular library for building node-based editors and interactive flow charts.",
  "keywords": [
    "angular",
    "node-based UI",
    "graph",
    "diagram",
    "workflow",
    "angular-flow",
    "angflow"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shisu89/angflow.git",
    "directory": "packages/angular"
  },
  "files": [
    "dist"
  ],
  "main": "dist/esm/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/esm/index.d.ts",
      "default": "./dist/esm/index.js"
    },
    "./layout": {
      "types": "./dist/esm/lib/layout/index.d.ts",
      "default": "./dist/esm/lib/layout/index.js"
    },
    "./dist/style.css": "./dist/style.css",
    "./dist/base.css": "./dist/base.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "ngc -p tsconfig.lib.json && node scripts/bundle-css.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@angflow/system": ">=0.1.2"
  },
  "peerDependencies": {
    "@angular/common": ">=19.0.0",
    "@angular/core": ">=19.0.0",
    "@dagrejs/dagre": ">=3.0.0",
    "rxjs": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "@dagrejs/dagre": {
      "optional": true
    }
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.5.3",
    "@angular/compiler": "^21.2.15",
    "@angular/compiler-cli": "^21.2.15",
    "@angular/platform-browser": "^21.2.15",
    "@angular/platform-browser-dynamic": "^21.2.7",
    "@dagrejs/dagre": "^3.0.0",
    "eslint": "^9.29.0",
    "jsdom": "^29.0.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.34.0",
    "vitest": "^4.1.2"
  }
}
