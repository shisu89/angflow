{
  "name": "@angflow/angular",
  "version": "0.0.8",
  "type": "module",
  "description": "Angular Flow - A highly customizable Angular library for building node-based editors and interactive flow charts.",
  "keywords": [
    "angular",
    "node-based UI",
    "graph",
    "diagram",
    "workflow",
    "angular-flow",
    "angflow"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/angflow/angflow.git",
    "directory": "packages/angular"
  },
  "files": [
    "dist"
  ],
  "main": "dist/esm/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/esm/index.d.ts",
      "default": "./dist/esm/index.js"
    },
    "./dist/style.css": "./dist/style.css",
    "./dist/base.css": "./dist/base.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "ngc -p tsconfig.lib.json && node scripts/bundle-css.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --ext .ts src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@angflow/system": ">=0.0.83"
  },
  "peerDependencies": {
    "@angular/common": ">=17.0.0",
    "@angular/core": ">=17.0.0",
    "rxjs": ">=7.0.0"
  },
  "devDependencies": {
    "@angular/compiler": ">=17.0.0",
    "@angular/compiler-cli": ">=17.0.0",
    "@angular/platform-browser": "^21.2.7",
    "@angular/platform-browser-dynamic": "^21.2.7",
    "jsdom": "^29.0.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.2"
  }
}
